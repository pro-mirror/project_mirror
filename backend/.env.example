# OpenAI Configuration
OPENAI_API_KEY=sk-xxxx...

# Qdrant Configuration
QDRANT_URL=https://xxxx.qdrant.tech
QDRANT_API_KEY=xxxx...

# Neo4j Configuration
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=xxxx...

# Postgres Configuration（現在未使用・Keycloak導入時に使用予定）
DATABASE_PUBLIC_URL=

# Server Configuration
HOST=0.0.0.0
PORT=8080
RUST_LOG=info

# ===== 将来の機能: Keycloak マルチユーザー認証 =====
# 【未実装】以下の環境変数は将来のKeycloak統合時に使用
# KEYCLOAK_URL=https://keycloak.your-domain.com
# KEYCLOAK_REALM=project-mirror
# KEYCLOAK_CLIENT_ID=backend-api
# KEYCLOAK_CLIENT_SECRET=xxxx...
# KEYCLOAK_ADMIN_USER=admin
# KEYCLOAK_ADMIN_PASSWORD=xxxx...
# 
# Keycloak用PostgreSQL（Railway上で別サービスとして作成予定）
# POSTGRES_URL=postgres://user:password@host:port/keycloak_db
# ==============================================
